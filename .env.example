# ─────────────────────────────────────────────────────────────
# OLX Hunter Bot — environment configuration
#
# FOR LOCAL DEV ONLY. Copy to `.env` and fill in the values. Never commit `.env`.
#
# In PRODUCTION there is NO .env on the droplet: TELEGRAM_BOT_TOKEN,
# ALLOWED_USER_IDS and HTTP_PROXY_URL come from GitHub Actions Secrets and are
# injected into the container at deploy time. See README → Deployment.
# ─────────────────────────────────────────────────────────────

# --- Telegram (required) ---
# Token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token_here

# --- Access control (required) ---
# Comma-separated list of allowed Telegram numeric user IDs.
# Anyone not on this list gets a polite "access restricted" reply.
# Find your ID by messaging @userinfobot.
ALLOWED_USER_IDS=123456789,987654321

# --- Redis ---
# In Docker Compose this is overridden to redis://redis:6379.
# For local dev against a local redis, use redis://127.0.0.1:6379.
REDIS_URL=redis://127.0.0.1:6379
# Prefix for every key this bot writes (keeps it tidy if the redis is shared).
REDIS_KEY_PREFIX=olx

# --- Polling ---
# Base interval between polling cycles, in milliseconds. Start conservative.
# 300000 = 5 minutes.
POLL_INTERVAL_MS=300000
# Random +/- jitter added to each cycle, in milliseconds, to look less robotic.
POLL_JITTER_MS=60000

# --- Scraper ---
# Global source mode: mock | http
#   mock -> deterministic fake listings from every source, no network. Use this
#           to try the bot end-to-end (wizard, dedup, per-source notifications)
#           without touching any site.
#   http -> real best-effort scraping of the enabled sources below.
SCRAPER=mock

# Which sites to track (comma-separated). Default = all known sources.
# Available: olx, rieltor, domria, lun, flatfy, birdrent, josti
# Note: lun & flatfy are the same company (LUN) and flatfy also aggregates
# OLX + DOM.RIA, so enabling everything surfaces the same flat more than once.
SOURCES=olx,rieltor,domria,lun,flatfy,birdrent,josti

# Base OLX domain + apartment category path (OLX http source only).
OLX_BASE_URL=https://www.olx.ua
OLX_CATEGORY_PATH=uk/nedvizhimost/kvartiry

# DOM.RIA official API key (https://developers.ria.com). Without it the domria
# source returns nothing in http mode. This is the only source with real data
# out of the box once the key is set.
# DOMRIA_API_KEY=
# DOMRIA_BASE_URL=https://developers.ria.com

# Optional outbound proxy for the scrapers, e.g. http://user:pass@host:port
# Datacenter IPs are sometimes blocked — route through a proxy if needed.
# HTTP_PROXY_URL=

# Per-request timeout (ms) and max retries for all http sources.
SCRAPER_TIMEOUT_MS=15000
SCRAPER_MAX_RETRIES=3

# --- Logging ---
# error | warn | log | debug | verbose
LOG_LEVEL=log
